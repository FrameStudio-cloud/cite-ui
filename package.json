{
  "name": "cite-ui",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/cite-ui.umd.js",
  "module": "dist/cite-ui.es.js",
  "exports": {
    ".": {
      "import": "./dist/cite-ui.es.js",
      "require": "./dist/cite-ui.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vite --open /docs.html",
    "docs:build": "vite build --config vite.docs.config.js"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
